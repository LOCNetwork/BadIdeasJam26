  messageText: {fileID: 570885393}
  confirmButton: {fileID: 981920911}
  closeButton: {fileID: 1564039649}
  normalOpenMessage: If you need more money, I can help by giving you 10$ as long
    as you return 15$ on quota!
  lowMoneyOpenMessage: You seem like you need money... I'll give you 10$ if you give
    back 15$ on quota, deal?
  lowMoneyThreshold: 6
  quotaIncreaseAmount: 15
